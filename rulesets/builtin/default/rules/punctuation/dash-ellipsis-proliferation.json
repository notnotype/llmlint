  {
    "id": "cn.punctuation.dash-ellipsis-proliferation.cn-inline-dash-to-comma",
    "namespace": "punctuation.dash-ellipsis-proliferation",
    "title": "中文间破折号变逗号",
    "level": "medium",
    "enabled": false,
    "note": "中文间破折号变逗号",
    "source": {
      "canonicalKey": "punctuation.dash-ellipsis-proliferation\t\t(?<=[\\u4e00-\\u9fff])—+(?=[\\u4e00-\\u9fff])",
      "importedFrom": ".agent/workspace/llmlint_rules"
    },
    "detector": {
      "type": "regex",
      "targets": [
        "(?<=[\\u4e00-\\u9fff])—+(?=[\\u4e00-\\u9fff])"
      ]
    },
    "action": {
      "type": "replace",
      "replacements": [
        "，"
      ]
    }
