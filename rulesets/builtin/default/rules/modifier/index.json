[
  {
    "id": "adverb-intensifier",
    "namespace": "modifier",
    "title": "过度副词和强化词",
    "level": "low",
    "note": "强化词常用来替代具体程度或证据。",
    "detector": {
      "type": "regex",
      "targets": [
        "非常|十分|极其|特别|高度|深刻地|充分地|有效地|显著地|真正地|完全地|本质上|根本上"
      ]
    },
    "action": {
      "type": "suggest",
      "message": "如果强化词没有提供具体程度，建议删除或改成事实、数字、动作。"
    }
  },
  {
    "id": "tier2-official-collocation",
    "namespace": "modifier",
    "title": "官腔动副搭配",
    "level": "low",
    "note": "「显著提升 / 有效解决 / 全面推进 / 持续优化」式公文腔搭配，单看就偏 AI/官样。改成具体动作与可观察结果；同段聚集时更应处理。",
    "detector": {
      "type": "regex",
      "targets": [
        "(?:显著|有效|全面|积极|持续|进一步|充分|切实|大力)(?:地)?(?:提升|改善|增长|解决|推动|促进|覆盖|推进|升级|探索|参与|优化|深化|加强|完善|发挥|利用|体现|保障|落实)"
      ]
    },
    "action": {
      "type": "suggest",
      "message": "改成具体动作 + 可观察结果，说清楚谁做了什么、变化是什么。"
    }
  },
  {
    "id": "tier2-pseudo-praise",
    "namespace": "modifier",
    "title": "虚化评价副词",
    "level": "low",
    "note": "「可谓 / 堪称 / 追根溯源」是虚化的评价姿态，多数可删或改成直接陈述。",
    "detector": {
      "type": "regex",
      "targets": [
